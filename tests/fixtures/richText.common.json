{
  "commonCases": [
    {
      "name": "[Common/Structure] 普通文本与 inline 混合 -> 应当保持相邻文本不塌陷",
      "mode": "parse",
      "input": "before $$bold(mid)$$ after",
      "depth": 50,
      "richTextEnabled": true,
      "expectedTokens": [
        { "type": "text", "value": "before " },
        { "type": "bold", "value": [{ "type": "text", "value": "mid" }] },
        { "type": "text", "value": " after" }
      ]
    },
    {
      "name": "[Common/Depth] 超过嵌套深度限制 (Inline) -> 应当将深层标签保留为纯文本",
      "mode": "parse",
      "input": "$$bold($$bold($$bold(hi)$$)$$)$$",
      "depth": 2,
      "richTextEnabled": true,
      "expectedTokens": [
        {
          "type": "bold",
          "value": [
            {
              "type": "bold",
              "value": [{ "type": "text", "value": "$$bold(hi)$$" }]
            }
          ]
        }
      ]
    },
    {
      "name": "[Common/Depth] 超过嵌套深度限制 (Complex) -> 应当将深层块保留为纯文本",
      "mode": "parse",
      "input": "$$collapse(A)*\n$$collapse(B)*\n$$collapse(C)*\nhello\n*end$$\n*end$$\n*end$$",
      "depth": 2,
      "richTextEnabled": true,
      "expectedTokens": [
        {
          "type": "collapse",
          "title": "A",
          "value": [
            {
              "type": "collapse",
              "title": "B",
              "value": [{ "type": "text", "value": "$$collapse(C)*\nhello\n*end$$" }]
            }
          ]
        }
      ]
    },
    {
      "name": "[Common/Escape] 转义分隔符与闭合符 -> 应当被视为普通文本处理",
      "mode": "strip",
      "input": "$$warning(标题里有 \\| 竖线 | 正文里有右括号 \\) 和反斜杠 \\\\)$$",
      "expectedText": "正文里有右括号 ) 和反斜杠 \\"
    },
    {
      "name": "[Common/Escape] 转义字符与闭合符混用 -> 应当正确解析文本而不截断后续标签",
      "mode": "parse",
      "input": "$$bold(a \\)$$ b)$$ $$thin(ok)$$",
      "depth": 50,
      "richTextEnabled": true,
      "expectedTokens": [
        { "type": "bold", "value": [{ "type": "text", "value": "a )$$ b" }] },
        { "type": "text", "value": " " },
        { "type": "thin", "value": [{ "type": "text", "value": "ok" }] }
      ]
    },
    {
      "name": "[Common/Boundary] 孤立闭合符 -> 应当直接作为普通文本保留",
      "mode": "strip",
      "input": ")$",
      "expectedText": ")$"
    },
    {
      "name": "[Common/Recovery] 坏标签后接好标签 -> 应当能跳过损坏部分并恢复解析",
      "mode": "parse",
      "input": "$$bold(bad) $$$$thin(good)$$",
      "depth": 50,
      "richTextEnabled": true,
      "expectedTokens": [
        { "type": "text", "value": "$$bold(bad) $$" },
        { "type": "thin", "value": [{ "type": "text", "value": "good" }] }
      ]
    },
    {
      "name": "[Common/Recovery] 未闭合前缀后接合法标签 -> 应当能正确识别并解析后续 token",
      "mode": "parse",
      "input": "$$bold(unclosed $$thin(ok)$$ $$underline(good)$$",
      "depth": 50,
      "richTextEnabled": true,
      "expectedTokens": [
        { "type": "text", "value": "$$bold(unclosed " },
        { "type": "thin", "value": [{ "type": "text", "value": "ok" }] },
        { "type": "text", "value": " " },
        { "type": "underline", "value": [{ "type": "text", "value": "good" }] }
      ]
    }
  ],
  "pipeCases": [
    {
      "input": "$$info(A|B)$$ ",
      "expectedTitle": "A",
      "expectedValue": [{ "type": "text", "value": "B" }]
    },
    {
      "input": "$$info(A|  B)$$ ",
      "expectedTitle": "A",
      "expectedValue": [{ "type": "text", "value": "B" }]
    },
    {
      "input": "$$info(A  |B)$$ ",
      "expectedTitle": "A",
      "expectedValue": [{ "type": "text", "value": "B" }]
    },
    {
      "input": "$$info(A | B)$$ ",
      "expectedTitle": "A",
      "expectedValue": [{ "type": "text", "value": "B" }]
    },
    {
      "input": "$$info(A | B  )$$ ",
      "expectedTitle": "A",
      "expectedValue": [{ "type": "text", "value": "B  " }]
    }
  ]
}
