{
  "cases": [
    {
      "name": "[Raw/Pipe] raw 块参数包含管道符 -> 应当支持拆分为 lang/title/label",
      "mode": "parse",
      "input": "$$raw-code(ts | 标题 | 标签)%\n代码\n%end$$",
      "expectedTokens": [
        {
          "type": "raw-code",
          "codeLang": "typescript",
          "title": "标题",
          "label": "标签",
          "value": "代码"
        }
      ]
    },
    {
      "name": "[Raw/Pipe] raw 块内容包含管道符 -> 应当直接保留为普通文本",
      "mode": "parse",
      "input": "$$raw-code(ts)%\nA | B\n%end$$",
      "expectedTokens": [
        {
          "type": "raw-code",
          "codeLang": "typescript",
          "title": "Code:",
          "label": "",
          "value": "A | B"
        }
      ]
    },
    {
      "name": "[Block/Basic] 基础 block 标签 -> 应当正常解析块级语法并包含内容",
      "mode": "parse",
      "input": "$$collapse(点我展开)*\nhello\n*end$$",
      "expectedTokens": [
        {
          "type": "collapse",
          "title": "点我展开",
          "value": [{ "type": "text", "value": "hello" }]
        }
      ]
    },
    {
      "name": "[Block/Degrade] 不支持 block 语法的标签 -> 应当退化为普通文本",
      "mode": "strip",
      "input": "$$center(hello)*\nworld\n*end$$",
      "expectedText": "$$center(hello)*\nworld\n*end$$"
    },
    {
      "name": "[Block/Boundary] 未闭合 block 标签 -> 应当退化为普通文本",
      "mode": "strip",
      "input": "$$collapse(Title)*\nhello",
      "expectedText": "$$collapse(Title)*\nhello"
    },
    {
      "name": "[Block/Escape] 内容中包含转义闭合符 -> 应当保留该符号并直到遇到真实闭合",
      "mode": "parse",
      "input": "$$collapse(Title)*\na\\*end$$\n*end$$",
      "expectedTokens": [
        {
          "type": "collapse",
          "title": "Title",
          "value": [{ "type": "text", "value": "a*end$$" }]
        }
      ]
    },
    {
      "name": "[Block/Unknown] 未知 block 语法 -> 应当整体退化为普通文本",
      "mode": "strip",
      "input": "$$unknown(title)*\nhello\n*end$$",
      "expectedText": "$$unknown(title)*\nhello\n*end$$"
    },
    {
      "name": "[Block/Unknown] 文本混入未知 block -> 应当视为单一文本段而不进行块解析",
      "mode": "strip",
      "input": "before $$unknown(x)*\nhello\n*end$$ after",
      "expectedText": "before $$unknown(x)*\nhello\n*end$$ after"
    },
    {
      "name": "[Block/Pipe] block 标题包含管道符 -> 应当不进行拆分 (与 inline 逻辑不同)",
      "mode": "parse",
      "input": "$$info(标题 | 正文)*\n内容\n*end$$",
      "expectedTokens": [
        {
          "type": "info",
          "title": "标题 | 正文",
          "value": [{ "type": "text", "value": "内容" }]
        }
      ]
    },
    {
      "name": "[Block/Pipe] block 内容包含管道符 -> 应当直接保留为普通文本",
      "mode": "parse",
      "input": "$$info(标题)*\nA | B\n*end$$",
      "expectedTokens": [
        {
          "type": "info",
          "title": "标题",
          "value": [{ "type": "text", "value": "A | B" }]
        }
      ]
    },
    {
      "name": "[Block/Boundary] 空 collapse block -> 应当回退默认标题并保留空内容列表",
      "mode": "parse",
      "input": "$$collapse()*\n*end$$",
      "expectedTokens": [
        {
          "type": "collapse",
          "title": "Click to expand content",
          "value": []
        }
      ]
    }
  ]
}
